GET http://localhost:4000/author-api/articles/69896df195fc9d6f77339cbe



### update article
PUT http://localhost:4000/author-api/articles
Content-Type: application/json

{
    "author":"69896df195fc9d6f77339cbe",
    "articleId":"69899cbcb7d9da75aaa2ac12",
    "title":"test 2 article - updated ok",
    "category":"testing updated",
    "content":"test data - hello world......... updated"
}

### delete article
DELETE http://localhost:4000/author-api/articles
Content-Type: application/json

{
    "author":"69896df195fc9d6f77339cbe",
    "articleId":"69897aed1fca3ae57211335c"
}





